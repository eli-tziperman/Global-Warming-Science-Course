# linear regresion to global fire area:
x=1.0*global_fire_years.T; y=1.0*global_all_fire_area.T;
fit=linregress(x, y)
global_all_fire_area_fit=fit.slope*global_fire_years+fit.intercept
print("global fire regression, p=%g, r^2=%g" % (fit.pvalue,fit.rvalue**2))

ax1=plt.gca()
ax1.plot(global_fire_years,global_all_fire_area/1.0e6,'b')
ax1.plot(global_fire_years,global_all_fire_area/1.0e6,'.',markersize=2,color='k')
ax1.plot(global_fire_years,global_all_fire_area_fit/1.0e6,lw=0.5,color='b')
ax1.set_xticks(np.arange(1970,2025,1), minor=True)
ax1.set_xlabel("Year")
ax1.set_ylabel("Global area burnt ($10^6$ km$^2$)",color="b")
ax1.set_title("(d)",loc="left",fontsize=fontsize)
ax1.tick_params(axis='y', colors="b")
ax1.grid(lw=0.25)

# linear regresion to west US fire area:
x=1.0*west_US_years; y=1.0*west_US_area_burnt;
fit=linregress(x, y)
west_US_area_burnt_fit=fit.slope*west_US_years+fit.intercept
print("west US fire regression, p=%g, r^2=%g" % (fit.pvalue,fit.rvalue**2))

ax2=ax1.twinx()
ax2.plot(west_US_years,west_US_area_burnt/1000,lw=1,color="r")
ax2.plot(west_US_years,west_US_area_burnt/1000,'.',markersize=2,color="k")
ax2.plot(west_US_years,west_US_area_burnt_fit/1000,lw=0.5,color='r')
ax2.set_ylabel("West US area burnt ($10^3$ km$^2$)",color="r")
ax2.tick_params(axis='y', colors="r")


